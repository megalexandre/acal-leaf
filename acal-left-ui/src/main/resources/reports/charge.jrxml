<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="charge" pageWidth="595" pageHeight="842" columnWidth="555"
              leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <property name="com.jaspersoft.studio.data.defaultdataadapter" value="One Empty Record"/>
    <parameter name="logo" class="java.awt.image.BufferedImage"/>
    <parameter name="SUBREPORT_TITLE"    class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="SUBREPORT_DETAIL"   class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="SUBREPORT_INVOICES" class="net.sf.jasperreports.engine.JasperReport"/>
    <queryString><![CDATA[]]></queryString>
    <field name="partnerName"   class="java.lang.String"/>
    <field name="address"       class="java.lang.String"/>
    <field name="addressNumber" class="java.lang.String"/>
    <field name="category"      class="java.lang.String"/>
    <field name="total"         class="java.lang.String"/>
    <field name="level"         class="java.lang.String"/>
    <field name="invoices"      class="java.util.List"/>
    <detail>
        <!-- Cabeçalho ACAL -->
        <band height="115" splitType="Prevent">
            <subreport isUsingCache="false">
                <reportElement x="0" y="0" width="555" height="115"/>
                <subreportParameter name="logo">
                    <subreportParameterExpression><![CDATA[$P{logo}]]></subreportParameterExpression>
                </subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource()]]></dataSourceExpression>
                <subreportExpression><![CDATA[$P{SUBREPORT_TITLE}]]></subreportExpression>
            </subreport>
        </band>
        <!-- Dados do cliente, tabela de débitos e texto legal -->
        <band height="370" splitType="Prevent">
            <subreport isUsingCache="false">
                <reportElement x="0" y="0" width="555" height="370"/>
                <subreportParameter name="SUBREPORT_INVOICES">
                    <subreportParameterExpression><![CDATA[$P{SUBREPORT_INVOICES}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="partnerName">
                    <subreportParameterExpression><![CDATA[$F{partnerName}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="address">
                    <subreportParameterExpression><![CDATA[$F{address}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="category">
                    <subreportParameterExpression><![CDATA[$F{category}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="total">
                    <subreportParameterExpression><![CDATA[$F{total}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="level">
                    <subreportParameterExpression><![CDATA[$F{level}]]></subreportParameterExpression>
                </subreportParameter>
                <subreportParameter name="invoices">
                    <subreportParameterExpression><![CDATA[$F{invoices}]]></subreportParameterExpression>
                </subreportParameter>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.JREmptyDataSource()]]></dataSourceExpression>
                <subreportExpression><![CDATA[$P{SUBREPORT_DETAIL}]]></subreportExpression>
            </subreport>
        </band>
        <!-- Linha serrilhada -->
        <band height="20">
            <staticText>
                <reportElement x="0" y="5" width="555" height="10"/>
                <textElement textAlignment="Center"><font size="7"/></textElement>
                <text><![CDATA[- - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -]]></text>
            </staticText>
        </band>
        <!-- Quebra de página entre clientes -->
        <band height="2">
            <break>
                <reportElement x="0" y="1" width="555" height="1"/>
            </break>
        </band>
    </detail>
</jasperReport>

