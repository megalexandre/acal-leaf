<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="charge_detail" pageWidth="555" pageHeight="842" columnWidth="555"
              leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0">
    <parameter name="SUBREPORT_INVOICES" class="net.sf.jasperreports.engine.JasperReport"/>
    <parameter name="partnerName"  class="java.lang.String"/>
    <parameter name="address"      class="java.lang.String"/>
    <parameter name="category"     class="java.lang.String"/>
    <parameter name="total"        class="java.lang.String"/>
    <parameter name="level"        class="java.lang.String"/>
    <parameter name="invoices"     class="java.util.List"/>
    <queryString><![CDATA[]]></queryString>
    <detail>
        <!-- Saudação + dados do cliente -->
        <band height="85" splitType="Prevent">
            <staticText>
                <reportElement x="0" y="0" width="100" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Prezado(a) Cliente:]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="105" y="0" width="450" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{partnerName}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="18" width="75" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Endereço:]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="80" y="18" width="475" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{address}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="36" width="75" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Categoria:]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="80" y="36" width="475" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{category}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="54" width="75" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Tipo de Aviso:]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="80" y="54" width="475" height="15"/>
                <textElement verticalAlignment="Middle"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$P{level}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="72" width="555" height="12"/>
                <textElement verticalAlignment="Middle"><font size="7" isItalic="true"/></textElement>
                <text><![CDATA[Lages do Batata, Jacobina/BA]]></text>
            </staticText>
        </band>

        <!-- Cabeçalho da tabela -->
        <band height="25" splitType="Prevent">
            <staticText>
                <reportElement mode="Opaque" x="0" y="0" width="100" height="25" backcolor="#CCCCCC"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[BOLETO Nº]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="100" y="0" width="155" height="25" backcolor="#CCCCCC"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[REF.]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="255" y="0" width="155" height="25" backcolor="#CCCCCC"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[VENCIMENTO]]></text>
            </staticText>
            <staticText>
                <reportElement mode="Opaque" x="410" y="0" width="145" height="25" backcolor="#CCCCCC"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[VALOR DO DÉBITO (R$)]]></text>
            </staticText>
        </band>

        <!-- Linhas de faturas via subreport -->
        <band height="100" splitType="Stretch">
            <subreport isUsingCache="false">
                <reportElement x="0" y="0" width="555" height="100" stretchType="ContainerHeight"/>
                <dataSourceExpression><![CDATA[new net.sf.jasperreports.engine.data.JRBeanCollectionDataSource($P{invoices})]]></dataSourceExpression>
                <subreportExpression><![CDATA[$P{SUBREPORT_INVOICES}]]></subreportExpression>
            </subreport>
        </band>

        <!-- Total -->
        <band height="25" splitType="Prevent">
            <staticText>
                <reportElement mode="Opaque" x="0" y="0" width="410" height="25" backcolor="#EEEEEE"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="9" isBold="true"/>
                    <paragraph rightIndent="5"/>
                </textElement>
                <text><![CDATA[Total do débito:]]></text>
            </staticText>
            <textField>
                <reportElement mode="Opaque" x="410" y="0" width="145" height="25" backcolor="#EEEEEE"/>
                <box><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{total}]]></textFieldExpression>
            </textField>
        </band>

        <!-- Aviso / texto legal -->
        <band height="120" splitType="Prevent">
            <staticText>
                <reportElement x="0" y="8" width="555" height="110"/>
                <textElement verticalAlignment="Top">
                    <font size="8"/>
                    <paragraph lineSpacing="1_1_2"/>
                </textElement>
                <text><![CDATA[Segundo nossos cadastros, estes débitos constam em aberto, para garantir a continuidade da prestação do serviço os débitos devem ser pagos.

A ACAL alerta que após 10 (dez) dias corridos a partir da data de emissão desta carta, caso o cliente não quite os débitos, a unidade consumidora sofrerá a suspensão do fornecimento de água, nos termos do estatuto desta entidade, artigo 7º - Deveres dos Associados.

Para esclarecimento e regularização entre em contato ou compareça ao escritório da ACAL.]]></text>
            </staticText>
        </band>

        <!-- Canhoto resumido -->
        <band height="25" splitType="Prevent">
            <staticText>
                <reportElement x="0" y="5" width="100" height="15"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Prezado(a) Cliente:]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="105" y="5" width="450" height="15"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{partnerName}]]></textFieldExpression>
            </textField>
        </band>
        <band height="20">
            <staticText>
                <reportElement x="0" y="2" width="65" height="14"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Endereço:]]></text>
            </staticText>
            <textField textAdjust="StretchHeight">
                <reportElement x="68" y="2" width="487" height="14"/>
                <textElement verticalAlignment="Middle"><font size="8"/></textElement>
                <textFieldExpression><![CDATA[$P{address}]]></textFieldExpression>
            </textField>
        </band>
        <band height="20">
            <staticText>
                <reportElement x="0" y="2" width="130" height="14"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <text><![CDATA[Valor do(s) débito(s):]]></text>
            </staticText>
            <textField>
                <reportElement x="133" y="2" width="200" height="14"/>
                <textElement verticalAlignment="Middle"><font size="8" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$P{total}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
</jasperReport>

